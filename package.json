{
  "name": "crt-themes",
  "version": "0.6.0",
  "description": "Color themes for a more civilized age",
  "keywords": [
    "theme",
    "color-theme",
    "monochrome",
    "terminal"
  ],
  "displayName": "CRT Themes",
  "publisher": "krueger71",
  "author": {
    "name": "Fredrik Andersson",
    "url": "https://github.com/krueger71"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/krueger71/crt-themes.git"
  },
  "bugs": {
    "url": "https://github.com/krueger71/crt-themes/issues"
  },
  "license": "MIT",
  "config": {
    "themes": {
      "CRT 64": {
        "type": "dark",
        "fg": "#6c5eb5",
        "bg": "#352879"
      },
      "CRT Amber": {
        "type": "dark",
        "fg": "#ffb000",
        "bg": "#111111"
      },
      "CRT Blue": {
        "type": "dark",
        "fg": "#0099ff",
        "bg": "#111111"
      },
      "CRT Custom": {
        "type": "dark",
        "fg": "#ffffff",
        "bg": "#000000"
      },
      "CRT Gray": {
        "type": "dark",
        "fg": "#bbbbbb",
        "bg": "#111111"
      },
      "CRT Green": {
        "type": "dark",
        "fg": "#33ff00",
        "bg": "#111111"
      },
      "CRT Red": {
        "type": "dark",
        "fg": "#ff2222",
        "bg": "#111111"
      },
      "CRT Paper": {
        "type": "light",
        "fg": "#0f0f0f",
        "bg": "#f0f0f0"
      }
    }
  },
  "engines": {
    "vscode": "^1.115.0"
  },
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#050",
    "theme": "dark"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "commands": [
      {
        "command": "crt-themes.helloWorld",
        "title": "Hello World"
      }
    ],
    "themes": [
      {
        "label": "CRT 64",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-64-color-theme.json"
      },
      {
        "label": "CRT Amber",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Amber-color-theme.json"
      },
      {
        "label": "CRT Blue",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Blue-color-theme.json"
      },
      {
        "label": "CRT Custom",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Custom-color-theme.json"
      },
      {
        "label": "CRT Gray",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Gray-color-theme.json"
      },
      {
        "label": "CRT Green",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Green-color-theme.json"
      },
      {
        "label": "CRT Red",
        "uiTheme": "vs-dark",
        "path": "./themes/CRT-Red-color-theme.json"
      },
      {
        "label": "CRT Paper",
        "uiTheme": "vs",
        "path": "./themes/CRT-Paper-color-theme.json"
      }
    ]
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "scripts": {
    "clean": "rm -rf build themes out",
    "build": "npm run compile && mkdir -p themes && for x in 64 Amber Blue Custom Gray Green Red Paper; do node src/build.js $x > themes/CRT-$x-color-theme.json; done",
    "package": "mkdir -p build && vsce package -o ./build",
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.3",
    "typescript-eslint": "^8.56.1",
    "typescript": "^5.9.3"
  }
}
